<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HERO SECTION -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="300dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivBanner"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@color/primary_light"
                    app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.Corner16dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/gradient_overlay" />

                <!-- Floating buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="@dimen/spacing_lg"
                    android:paddingTop="@dimen/spacing_xxxl">

                    <ImageView
                        android:id="@+id/btnBack"
                        android:layout_width="@dimen/icon_xl"
                        android:layout_height="@dimen/icon_xl"
                        android:padding="@dimen/spacing_xs"
                        android:background="@drawable/circle_primary_light"
                        android:src="@android:drawable/ic_menu_revert"
                        android:tint="@color/white" />

                    <Space
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1" />

                    <ImageView
                        android:id="@+id/btnShare"
                        android:layout_width="@dimen/icon_xl"
                        android:layout_height="@dimen/icon_xl"
                        android:layout_marginEnd="@dimen/spacing_sm"
                        android:padding="@dimen/spacing_xs"
                        android:background="@drawable/circle_primary_light"
                        android:src="@android:drawable/ic_menu_send"
                        android:tint="@color/white" />

                    <ImageView
                        android:id="@+id/btnFavorito"
                        android:layout_width="@dimen/icon_xl"
                        android:layout_height="@dimen/icon_xl"
                        android:padding="@dimen/spacing_xs"
                        android:background="@drawable/circle_primary_light"
                        android:src="@android:drawable/ic_menu_myplaces"
                        android:tint="@color/white" />
                </LinearLayout>

                <!-- Info sobre hero -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg"
                    android:layout_gravity="bottom">

                    <TextView
                        android:id="@+id/tvNombreDetalle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TableBitText.HeadlineLarge"
                        android:textColor="@color/white" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xxs"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvTipoDetalle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textAppearance="@style/TableBitText.BodyMedium"
                            android:textColor="@color/white"
                            android:alpha="0.9" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_sm"
                            android:text="\u00b7"
                            android:textColor="@color/white" />

                        <TextView
                            android:id="@+id/tvCiudadDetalle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_sm"
                            android:textAppearance="@style/TableBitText.BodyMedium"
                            android:textColor="@color/white"
                            android:alpha="0.9" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_sm"
                            android:text="\u00b7"
                            android:textColor="@color/white" />

                        <TextView
                            android:id="@+id/tvRatingDetalle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_sm"
                            android:textAppearance="@style/TableBitText.BodyMedium"
                            android:textColor="@color/secondary" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvEstadoDetalle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:textAppearance="@style/TableBitText.LabelSmall"
                        android:textColor="@color/success" />
                </LinearLayout>
            </FrameLayout>

            <!-- RESUMEN RÁPIDO -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/spacing_lg"
                android:layout_marginTop="-20dp"
                app:cardCornerRadius="@dimen/corner_xlarge"
                app:cardElevation="@dimen/elevation_xhigh"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvDireccionDetalle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:drawableStart="@android:drawable/ic_menu_compass"
                                android:drawablePadding="@dimen/spacing_xs"
                                android:textAppearance="@style/TableBitText.BodyMedium"
                                android:textColor="@color/text_primary" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvTelefonoDetalle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:drawableStart="@android:drawable/ic_menu_call"
                                android:drawablePadding="@dimen/spacing_xs"
                                android:textAppearance="@style/TableBitText.BodyMedium"
                                android:textColor="@color/text_primary" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvCapacidadDetalle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:drawableStart="@android:drawable/ic_menu_myplaces"
                            android:drawablePadding="@dimen/spacing_xs"
                            android:textAppearance="@style/TableBitText.BodyMedium"
                            android:textColor="@color/text_primary" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- GALERÍA -->
            <TextView
                android:id="@+id/tvGaleriaTitulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_lg"
                android:layout_marginTop="@dimen/spacing_xxl"
                android:text="Galer\u00eda"
                android:textAppearance="@style/TableBitText.TitleMedium"
                android:textColor="@color/text_primary"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvGaleria"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:orientation="horizontal"
                android:paddingStart="@dimen/spacing_lg"
                android:paddingEnd="@dimen/spacing_sm"
                android:visibility="gone"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            <!-- HORARIOS -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_lg"
                android:layout_marginTop="@dimen/spacing_xxl"
                android:textAppearance="@style/TableBitText.TitleMedium"
                android:textColor="@color/text_primary"
                android:text="Horarios" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/spacing_lg"
                android:layout_marginTop="@dimen/spacing_sm"
                app:cardCornerRadius="@dimen/corner_large"
                app:cardElevation="@dimen/elevation_low"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:id="@+id/containerHorarios"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg" />
            </com.google.android.material.card.MaterialCardView>

            <!-- DESCRIPCIÓN -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_lg"
                android:layout_marginTop="@dimen/spacing_xxl"
                android:textAppearance="@style/TableBitText.TitleMedium"
                android:textColor="@color/text_primary"
                android:text="Descripci\u00f3n" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/spacing_lg"
                android:layout_marginTop="@dimen/spacing_sm"
                app:cardCornerRadius="@dimen/corner_large"
                app:cardElevation="@dimen/elevation_low"
                app:cardBackgroundColor="@color/surface">

                <TextView
                    android:id="@+id/tvDescripcionDetalle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/spacing_lg"
                    android:textAppearance="@style/TableBitText.BodyMedium"
                    android:textColor="@color/text_primary"
                    android:lineSpacingExtra="4dp" />
            </com.google.android.material.card.MaterialCardView>

            <!-- RESEÑAS -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_lg"
                android:layout_marginTop="@dimen/spacing_xxl"
                android:textAppearance="@style/TableBitText.TitleMedium"
                android:textColor="@color/text_primary"
                android:text="Rese\u00f1as" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvResenas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:orientation="horizontal"
                android:paddingStart="@dimen/spacing_lg"
                android:paddingEnd="@dimen/spacing_sm"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            <LinearLayout
                android:id="@+id/layoutResenasEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/spacing_lg"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="\u2B50"
                    android:textSize="40sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:text="A\u00fan no hay rese\u00f1as"
                    android:textAppearance="@style/TableBitText.TitleSmall"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="S\u00e9 el primero en compartir tu experiencia"
                    android:textAppearance="@style/TableBitText.BodySmall"
                    android:textColor="@color/text_secondary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEscribirResena"
                    style="@style/TableBit.Button.Primary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:text="Escribir rese\u00f1a" />
            </LinearLayout>

            <!-- Footer spacer -->
            <View
                android:layout_width="match_parent"
                android:layout_height="100dp" />

        </LinearLayout>
    </NestedScrollView>

    <!-- FAB Reservar -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabReservar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_margin="@dimen/spacing_lg"
        android:backgroundTint="@color/primary"
        android:text="Reservar Mesa"
        android:textColor="@color/white"
        app:icon="@android:drawable/ic_menu_my_calendar"
        app:iconTint="@color/white" />
</LinearLayout>
