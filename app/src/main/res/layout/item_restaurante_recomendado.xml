<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_lg"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardCornerRadius="@dimen/corner_xlarge"
    app:cardElevation="@dimen/elevation_medium"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivRecomendado"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:scaleType="centerCrop"
            android:src="@color/primary_light"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.Corner12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="@dimen/spacing_md">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvNombreRecomendado"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TableBitText.TitleMedium"
                    android:textColor="@color/text_primary" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xxs"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvRatingRecomendado"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TableBitText.BodySmall"
                        android:textColor="@color/secondary" />

                    <TextView
                        android:id="@+id/tvTipoRecomendado"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_sm"
                        android:textAppearance="@style/TableBitText.BodySmall"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvCiudadRecomendado"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_sm"
                        android:textAppearance="@style/TableBitText.BodySmall"
                        android:textColor="@color/text_disabled" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvEstadoRecomendado"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xxs"
                    android:textAppearance="@style/TableBitText.LabelSmall"
                    android:textColor="@color/success" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReservarRecomendado"
                style="@style/TableBit.Button.Primary"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/height_button_small"
                android:text="Reservar"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
