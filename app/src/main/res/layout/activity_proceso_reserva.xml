<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <!-- Restaurant Header -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="0dp"
        app:cardElevation="@dimen/elevation_medium"
        app:cardBackgroundColor="@color/surface">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="@dimen/spacing_lg">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivRestauranteReserva"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:scaleType="centerCrop"
                android:src="@color/primary_light"
                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.Corner8dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="@dimen/spacing_md">

                <TextView
                    android:id="@+id/tvNombreReserva"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TableBitText.TitleMedium"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/tvInfoReserva"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xxs"
                    android:textAppearance="@style/TableBitText.BodySmall"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>

            <ImageView
                android:id="@+id/btnCloseReserva"
                android:layout_width="@dimen/icon_lg"
                android:layout_height="@dimen/icon_lg"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:tint="@color/text_secondary" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Step Indicator -->
    <LinearLayout
        android:id="@+id/stepIndicator"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_lg"
        android:paddingBottom="@dimen/spacing_md">

        <TextView
            android:id="@+id/step1"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:background="@drawable/circle_primary"
            android:textColor="@color/on_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:text="1" />

        <View
            android:id="@+id/line1"
            android:layout_width="0dp"
            android:layout_height="2dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="@dimen/spacing_sm"
            android:background="@color/outline" />

        <TextView
            android:id="@+id/step2"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:background="@drawable/circle_primary"
            android:textColor="@color/on_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:text="2" />

        <View
            android:id="@+id/line2"
            android:layout_width="0dp"
            android:layout_height="2dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="@dimen/spacing_sm"
            android:background="@color/outline" />

        <TextView
            android:id="@+id/step3"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:background="@drawable/circle_primary"
            android:textColor="@color/on_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:text="3" />
    </LinearLayout>

    <!-- Step Label -->
    <TextView
        android:id="@+id/tvStepLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/spacing_lg"
        android:textAppearance="@style/TableBitText.HeadlineSmall"
        android:textColor="@color/text_primary" />

    <TextView
        android:id="@+id/tvStepSubLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/spacing_lg"
        android:paddingTop="@dimen/spacing_xxs"
        android:textAppearance="@style/TableBitText.BodyMedium"
        android:textColor="@color/text_secondary" />

    <!-- Content Area -->
    <ScrollView
        android:id="@+id/scrollContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_lg">

            <!-- Step 1: Fecha -->
            <LinearLayout
                android:id="@+id/stepFechaContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <CalendarView
                    android:id="@+id/calendarView"
                    android:layout_width="match_parent"
                    android:layout_height="300dp"
                    android:background="@color/surface" />

                <TextView
                    android:id="@+id/tvFechaSeleccionada"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_lg"
                    android:textAppearance="@style/TableBitText.TitleMedium"
                    android:textColor="@color/primary" />
            </LinearLayout>

            <!-- Step 2: Hora -->
            <LinearLayout
                android:id="@+id/stepHoraContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TableBitText.BodyMedium"
                    android:textColor="@color/text_secondary"
                    android:text="Horarios disponibles" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupHoras"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    app:chipSpacingHorizontal="@dimen/spacing_sm"
                    app:chipSpacingVertical="@dimen/spacing_sm"
                    app:singleLine="false"
                    app:singleSelection="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipHora12"
                        style="@style/TableBit.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="12:00" />
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipHora13"
                        style="@style/TableBit.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="13:00" />
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipHora14"
                        style="@style/TableBit.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="14:00" />
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipHora18"
                        style="@style/TableBit.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="18:00" />
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipHora19"
                        style="@style/TableBit.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="19:00" />
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipHora20"
                        style="@style/TableBit.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="20:00" />
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipHora21"
                        style="@style/TableBit.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="21:00" />
                </com.google.android.material.chip.ChipGroup>
            </LinearLayout>

            <!-- Step 3: Personas -->
            <LinearLayout
                android:id="@+id/stepPersonasContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMenos"
                        style="@style/Widget.Material3.Button.IconButton"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:text="-"
                        android:textSize="24sp"
                        app:cornerRadius="24dp" />

                    <TextView
                        android:id="@+id/tvCantidadPersonas"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="@dimen/spacing_xxl"
                        android:textAppearance="@style/TableBitText.DisplayMedium"
                        android:textColor="@color/primary"
                        android:text="2" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMas"
                        style="@style/Widget.Material3.Button.IconButton"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:text="+"
                        android:textSize="24sp"
                        app:cornerRadius="24dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Step 4: Resumen -->
            <LinearLayout
                android:id="@+id/stepResumenContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="@dimen/corner_xlarge"
                    app:cardElevation="@dimen/elevation_medium"
                    app:cardBackgroundColor="@color/surface">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_xxl">

                        <TextView
                            android:id="@+id/tvResumenRestaurante"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:drawableStart="@android:drawable/ic_menu_compass"
                            android:drawablePadding="@dimen/spacing_sm"
                            android:textAppearance="@style/TableBitText.TitleMedium"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:id="@+id/tvResumenFecha"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_md"
                            android:drawableStart="@android:drawable/ic_menu_today"
                            android:drawablePadding="@dimen/spacing_sm"
                            android:textAppearance="@style/TableBitText.BodyLarge"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:id="@+id/tvResumenHora"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:drawableStart="@android:drawable/ic_menu_my_calendar"
                            android:drawablePadding="@dimen/spacing_sm"
                            android:textAppearance="@style/TableBitText.BodyLarge"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:id="@+id/tvResumenPersonas"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:drawableStart="@android:drawable/ic_menu_myplaces"
                            android:drawablePadding="@dimen/spacing_sm"
                            android:textAppearance="@style/TableBitText.BodyLarge"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_lg"
                            android:textAppearance="@style/TableBitText.BodySmall"
                            android:textColor="@color/text_secondary"
                            android:text="TableBit encontrar\u00e1 autom\u00e1ticamente la mejor mesa disponible" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Bottom: Navigation Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_lg"
        android:background="@color/surface"
        android:elevation="@dimen/elevation_medium">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAtras"
            style="@style/TableBit.Button.Text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Atr\u00e1s"
            android:visibility="gone" />

        <Space
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSiguiente"
            style="@style/TableBit.Button.Primary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Siguiente" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmar"
            style="@style/TableBit.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Confirmar Reserva"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Success Overlay -->
    <FrameLayout
        android:id="@+id/successOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/primary"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/spacing_xxl">

            <TextView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:gravity="center"
                android:text="✅"
                android:textSize="48sp"
                android:background="@drawable/circle_primary_light" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:textAppearance="@style/TableBitText.HeadlineLarge"
                android:textColor="@color/white"
                android:text="Reserva Confirmada" />

            <TextView
                android:id="@+id/tvConfirmNumero"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:textAppearance="@style/TableBitText.BodyLarge"
                android:textColor="@color/white"
                android:alpha="0.9" />

            <TextView
                android:id="@+id/tvConfirmDetalle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:textAppearance="@style/TableBitText.BodyMedium"
                android:textColor="@color/white"
                android:alpha="0.7" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVerReservas"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="@dimen/spacing_xxl"
                android:backgroundTint="@color/white"
                android:text="Ver mis reservas"
                android:textColor="@color/primary"
                app:cornerRadius="@dimen/corner_medium" />
        </LinearLayout>
    </FrameLayout>

</LinearLayout>
