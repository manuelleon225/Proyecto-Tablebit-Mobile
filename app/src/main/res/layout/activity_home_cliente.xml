<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header premium -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/spacing_lg"
                android:paddingTop="@dimen/spacing_xxl">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvGreeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TableBitText.HeadlineSmall"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:id="@+id/tvDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xxs"
                        android:textAppearance="@style/TableBitText.BodyMedium"
                        android:textColor="@color/text_secondary" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvAvatarHome"
                    android:layout_width="@dimen/icon_large_avatar"
                    android:layout_height="@dimen/icon_large_avatar"
                    android:gravity="center"
                    android:background="@drawable/circle_primary"
                    android:textColor="@color/on_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Search Bar real -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/searchCard"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginHorizontal="@dimen/spacing_lg"
                android:layout_marginTop="@dimen/spacing_lg"
                android:paddingStart="@dimen/spacing_lg"
                app:cardCornerRadius="@dimen/corner_large"
                app:cardElevation="@dimen/elevation_medium"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingEnd="@dimen/spacing_sm">

                    <android.widget.EditText
                        android:id="@+id/etSearch"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="Buscar restaurantes, comida o ciudad..."
                        android:inputType="text"
                        android:maxLines="1"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_disabled"
                        android:textAppearance="@style/TableBitText.BodyMedium" />

                    <ImageView
                        android:id="@+id/ivSearchClear"
                        android:layout_width="@dimen/icon_lg"
                        android:layout_height="@dimen/icon_lg"
                        android:src="@android:drawable/ic_menu_close_clear_cancel"
                        android:tint="@color/text_disabled"
                        android:visibility="gone" />

                    <ImageView
                        android:layout_width="@dimen/icon_lg"
                        android:layout_height="@dimen/icon_lg"
                        android:layout_marginStart="@dimen/spacing_xs"
                        android:src="@android:drawable/ic_menu_search"
                        android:tint="@color/primary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ProgressBar de búsqueda -->
            <ProgressBar
                android:id="@+id/progressSearch"
                style="?android:attr/progressBarStyleSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="@dimen/spacing_xs"
                android:layout_marginEnd="@dimen/spacing_xxl"
                    android:visibility="gone" />

            <!-- Empty state de búsqueda -->
            <LinearLayout
                android:id="@+id/layoutSearchEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/spacing_xxl"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔍"
                    android:textSize="40sp" />

                <TextView
                    android:id="@+id/tvSearchEmptyTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:text="No encontramos restaurantes"
                    android:textAppearance="@style/TableBitText.TitleMedium"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/tvSearchEmptySub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:text="Intenta con otro nombre, tipo de comida o ciudad"
                    android:textAppearance="@style/TableBitText.BodySmall"
                    android:textColor="@color/text_secondary"
                    android:gravity="center" />
            </LinearLayout>

            <!-- Tarjeta: Tu próxima reserva -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardProximaReserva"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/spacing_lg"
                android:layout_marginTop="@dimen/spacing_md"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="@dimen/corner_xlarge"
                app:cardElevation="@dimen/elevation_high"
                app:strokeColor="@color/primary"
                app:strokeWidth="1dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tu pr\u00f3xima reserva"
                        android:textAppearance="@style/TableBitText.LabelLarge"
                        android:textColor="@color/primary" />

                    <TextView
                        android:id="@+id/tvProxRestaurante"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:textAppearance="@style/TableBitText.TitleMedium"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:id="@+id/tvProxFecha"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xxs"
                        android:textAppearance="@style/TableBitText.BodyMedium"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvProxPersonas"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TableBitText.BodySmall"
                        android:textColor="@color/text_secondary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Categorías horizontales -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_lg"
                android:layout_marginTop="@dimen/spacing_xxl"
                android:textAppearance="@style/TableBitText.TitleMedium"
                android:textColor="@color/text_primary"
                android:text="Categor\u00edas" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCategorias"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:orientation="horizontal"
                android:paddingStart="@dimen/spacing_lg"
                android:paddingEnd="@dimen/spacing_sm"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            <!-- Restaurante Destacado -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_lg"
                android:layout_marginTop="@dimen/spacing_xxl"
                android:textAppearance="@style/TableBitText.TitleMedium"
                android:textColor="@color/text_primary"
                android:text="Destacados" />

            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/vpDestacados"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="@dimen/spacing_sm" />

            <!-- Indicador de puntos -->
            <LinearLayout
                android:id="@+id/indicadorPuntos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/spacing_sm"
                android:orientation="horizontal" />

            <!-- Restaurantes Recomendados -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_lg"
                android:layout_marginTop="@dimen/spacing_xxl"
                android:textAppearance="@style/TableBitText.TitleMedium"
                android:textColor="@color/text_primary"
                android:text="Restaurantes recomendados" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRecomendados"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:paddingHorizontal="@dimen/spacing_lg"
                android:nestedScrollingEnabled="false" />

            <!-- Spacer para bottom nav -->
            <View
                android:layout_width="match_parent"
                android:layout_height="80dp" />

        </LinearLayout>
    </ScrollView>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        app:menu="@menu/menu_bottom_navigation"
        app:itemIconTint="@color/primary"
        app:itemTextColor="@color/text_secondary"
        app:labelVisibilityMode="labeled" />

</LinearLayout>
